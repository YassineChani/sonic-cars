# Database (required)
# Local dev: DATABASE_URL="file:./dev.db"
# Production (Neon.tech PostgreSQL): DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL="file:./dev.db"

# NextAuth (required - generate a secret: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-in-production-use-openssl-rand-base64-32"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp number (with country code, no spaces)
NEXT_PUBLIC_WHATSAPP="+212600000000"

# Email (optional - for booking confirmation emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SONIC CARS <contact@soniccars.ma>"
